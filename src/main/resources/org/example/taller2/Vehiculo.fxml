<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="400.0" prefWidth="600.0"
      style="-fx-background-color: #2D6BFF;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.taller2.Controlador.ControladorVehiculo">

   <children>

      <ImageView fitHeight="97.0" fitWidth="92.0" layoutX="-6.0" layoutY="-6.0" opacity="0.6">
         <image>
            <Image url="@/org/example/taller2/imagenes/Burbuja.png" />
         </image>
      </ImageView>

      <ImageView fitHeight="135.0" fitWidth="106.0" layoutY="265.0" opacity="0.5">
         <image>
            <Image url="@/org/example/taller2/imagenes/Burbuja.png" />
         </image>
      </ImageView>

      <ImageView fitHeight="97.0" fitWidth="106.0" layoutX="504.0" opacity="0.5">
         <image>
            <Image url="@/org/example/taller2/imagenes/burbuja2.png" />
         </image>
      </ImageView>

      <ImageView fitHeight="120.0" fitWidth="118.0" layoutX="485.0" layoutY="280.0" opacity="0.5">
         <image>
            <Image url="@/org/example/taller2/imagenes/burbuja2.png" />
         </image>
      </ImageView>

      <ImageView fitHeight="155.0" fitWidth="239.0" layoutX="95.0" layoutY="-6.0">
         <image>
            <Image url="@/org/example/taller2/imagenes/Carro.png" />
         </image>
      </ImageView>

      <Label layoutX="262.0" layoutY="43.0" text="ESFOTCAR" textFill="WHITE">
         <font>
            <Font name="System Bold" size="29.0" />
         </font>
      </Label>

      <Label layoutX="53.0" layoutY="119.0" text="Ingrese los datos del Vehículo" textFill="WHITE">
         <font>
            <Font size="20.0" />
         </font>
      </Label>

      <Label layoutX="64.0" layoutY="180.0" text="Código:" textFill="WHITE">
         <font><Font size="18.0" /></font>
      </Label>

      <Label layoutX="69.0" layoutY="215.0" text="Marca:" textFill="WHITE">
         <font><Font size="18.0" /></font>
      </Label>

      <Label layoutX="72.0" layoutY="249.0" text="Modelo:" textFill="WHITE">
         <font><Font size="18.0" /></font>
      </Label>

      <Label layoutX="69.0" layoutY="283.0" text="Precio:" textFill="WHITE">
         <font><Font size="18.0" /></font>
      </Label>

      <TextField fx:id="txtCodigo" layoutX="165.0" layoutY="179.0" prefHeight="30.0" prefWidth="195.0" />
      <TextField fx:id="txtMarca" layoutX="165.0" layoutY="214.0" prefHeight="30.0" prefWidth="195.0" />
      <TextField fx:id="txtModelo" layoutX="165.0" layoutY="248.0" prefHeight="30.0" prefWidth="195.0" />
      <TextField fx:id="txtPrecio" layoutX="165.0" layoutY="282.0" prefHeight="30.0" prefWidth="195.0" />

      <ImageView fitHeight="200.0" fitWidth="200.0" layoutX="385.0" layoutY="115.0">
         <image>
            <Image url="@/org/example/taller2/imagenes/carro1.png" />
         </image>
      </ImageView>

      <Button layoutX="138.0" layoutY="340.0"
              prefHeight="40.0" prefWidth="128.0"
              style="-fx-background-color: #7CB8FF;"
              text="EDITAR"
              onAction="#editar">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>

      <Button layoutX="303.0" layoutY="340.0"
              prefHeight="40.0" prefWidth="143.0"
              style="-fx-background-color: #7CB8FF;"
              text="GUARDAR"
              onAction="#guardar">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>

   </children>
</Pane>